:\\JoyMate\\src\\app\\api\\generate-art\\route.ts",[],[],"D:\\JoyMate\\src\\app\\api\\recommend\\route.ts",[],[],"D:\\JoyMate\\src\\app\\layout.tsx",[],[],"D:\\JoyMate\\src\\app\\page.tsx",[],[],"D:\\JoyMate\\src\\App.tsx",[],[],"D:\\JoyMate\\src\\components\\GameDetailsModal.tsx",["72"],[],"D:\\JoyMate\\src\\components\\ImageGeneratorModal.tsx",["73"],[],"D:\\JoyMate\\src\\components\\MainContent.tsx",["74","75","76","77","78","79","80"],[],"D:\\JoyMate\\src\\components\\RightSidebar.tsx",["81"],[],"D:\\JoyMate\\src\\components\\Sidebar.tsx",[],[],"D:\\JoyMate\\src\\lib\\gameI18n.ts",[],[],"D:\\JoyMate\\src\\lib\\rawg.ts",[],[],"D:\\JoyMate\\src\\services\\gemini.ts",[],[],{"ruleId":"82","severity":1,"message":"83","line":71,"column":17,"nodeType":"84","endLine":76,"endColumn":19},{"ruleId":"82","severity":1,"message":"83","line":87,"column":17,"nodeType":"84","endLine":87,"endColumn":100},{"ruleId":"85","severity":1,"message":"86","line":534,"column":9,"nodeType":"87","endLine":592,"endColumn":4,"suggestions":"88"},{"ruleId":"85","severity":1,"message":"89","line":674,"column":6,"nodeType":"90","endLine":674,"endColumn":8,"suggestions":"91"},{"ruleId":"82","severity":1,"message":"83","line":971,"column":43,"nodeType":"84","endLine":976,"endColumn":45},{"ruleId":"82","severity":1,"message":"83","line":1136,"column":19,"nodeType":"84","endLine":1136,"endColumn":132},{"ruleId":"82","severity":1,"message":"83","line":1137,"column":19,"nodeType":"84","endLine":1137,"endColumn":132},{"ruleId":"82","severity":1,"message":"83","line":1138,"column":19,"nodeType":"84","endLine":1138,"endColumn":132},{"ruleId":"82","severity":1,"message":"83","line":1193,"column":7,"nodeType":"84","endLine":1198,"endColumn":9},{"ruleId":"82","severity":1,"message":"83","line":12,"column":11,"nodeType":"84","endLine":12,"endColumn":144},"@next/next/no-img-element","Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","JSXOpeningElement","react-hooks/exhaustive-deps","The 'handleSend' function makes the dependencies of useCallback Hook (at line 717) change on every render. To fix this, wrap the definition of 'handleSend' in its own useCallback() Hook.","VariableDeclarator",["92"],"React Hook useCallback has a missing dependency: 'sendRecommendRequest'. Either include it or remove the dependency array.","ArrayExpression",["93"],{"desc":"94","fix":"95"},{"desc":"96","fix":"97"},"Wrap the definition of 'handleSend' in its own useCallback() Hook.",{"range":"98","text":"99"},"Update the dependencies array to be: [sendRecommendRequest]",{"range":"100","text":"101"},[20451,22877],"useCallback(async (\r\n    arg?: string | { displayText: string; promptText: string; updateIntent?: boolean; actionHint?: string },\r\n  ) => {\r\n    const isObj = typeof arg === 'object' && arg !== null;\r\n    const displayText = isObj ? arg.displayText : (arg ?? input).trim();\r\n    const promptText = isObj ? arg.promptText : displayText;\r\n    const updateIntent = isObj ? Boolean(arg.updateIntent) : true;\r\n    const actionHint = isObj ? arg.actionHint : undefined;\r\n\r\n    const rawDisplay = (displayText ?? '').trim();\r\n    const rawPrompt = (promptText ?? '').trim();\r\n    if (!rawDisplay || !rawPrompt) return;\r\n\r\n    if (updateIntent) lastUserIntentRef.current = rawPrompt;\r\n\r\n    const userMsg: Message = { id: Date.now().toString(), role: 'user', content: rawDisplay };\r\n    setMessages(prev => [...prev, userMsg]);\r\n    setInput('');\r\n    \r\n    // Scroll immediately after user sends message\r\n    setTimeout(() => scrollToBottom(\"smooth\"), 100);\r\n\r\n    const loadingId = (Date.now() + 1).toString();\r\n    setMessages(prev => [...prev, { id: loadingId, role: 'ai', isLoading: true }]);\r\n    setTimeout(() => scrollToBottom(\"smooth\"), 100);\r\n\r\n    try {\r\n      const data = await getGameRecommendation(buildPrompt(rawPrompt, actionHint));\r\n      const titles = Array.isArray(data?.recommended_games)\r\n        ? data.recommended_games\r\n            .map((g: any) => (typeof g?.title_ai === 'string' ? g.title_ai : g?.title))\r\n            .filter((t: any) => typeof t === 'string' && t.trim().length > 0)\r\n        : [];\r\n\r\n      if (titles.length) {\r\n        setSessionMemory(prev => {\r\n          const merged = Array.from(new Set([...prev.seen, ...titles]));\r\n          return { ...prev, seen: merged.slice(-40) };\r\n        });\r\n      }\r\n      // Reset state for animations if needed, though TypewriterText handles text changes\r\n      setMessages(prev => prev.map(msg => msg.id === loadingId ? { \r\n        id: loadingId, \r\n        role: 'ai', \r\n        data, \r\n        isLoading: false,\r\n        typingStage: (data.aesthetic_critic || data.hardcore_strategist || data.budget_expert) ? 'personas' : 'host'\r\n      } : msg));\r\n    } catch (error) {\r\n      console.error(error);\r\n      setMessages(prev => prev.map(msg => msg.id === loadingId ? { \r\n        id: loadingId, \r\n        role: 'ai', \r\n        data: { host_message: \"抱歉，我的分析引擎遇到了一点问题。请稍后再试。\" }, \r\n        isLoading: false,\r\n        typingStage: 'host'\r\n      } : msg));\r\n    }\r\n  })",[25628,25630],"[sendRecommendRequest]"]